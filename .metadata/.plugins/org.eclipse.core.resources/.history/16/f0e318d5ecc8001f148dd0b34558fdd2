<!doctype html>
<html lang="en">

<head>
	<meta charset="utf-8">
	<meta name="viewport" content="width=device-width, initial-scale=1">
	<title>DashBoard Page</title>
	<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"
		integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
</head>

<body>

	<div class="container">
		<h1>Dashboard Info</h1>

		<table>
			<tr>
				<td>Total Enquiry :</td>
				<td><input type="${dashboardDto.totalEnqCnt}" </td>
			</tr>
			<tr>
				<td>Open Enquiry :</td>
				<td><input type="${dashboardDto.openEnqCnt}" </td>
			</tr>
			<tr>
				<td>Enrolled Enquiry :</td>
				<td><input type="${dashboardDto.enrolledEnqCnt}" </td>
			</tr>
			<tr>
				<td>Lost Enquiry :</td>
				<td><input type="${dashboardDto.lostEnqCnt}" </td>
			</tr>
		</table>
	</div>



	<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"
		integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz"
		crossorigin="anonymous"></script>
</body>

</html>